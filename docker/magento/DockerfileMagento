# Imagen base: PHP 8.2 con Apache
FROM php:8.2-apache

# ===============================
# 1️⃣ Variables y configuraciones
# ===============================
# ARG define variables disponibles en tiempo de build
ARG DEBIAN_FRONTEND=noninteractive
ARG UID 

# Directorio de trabajo dentro del contenedor
WORKDIR /var/www/html

# ===============================
# 2️⃣ Dependencias necesarias
# ===============================
# RUN instala paquetes del sistema necesarios para build y ejecución
RUN apt-get update && apt-get install -y \
    libssl-dev unzip curl cron git gnupg default-mysql-client mariadb-client \
    libpng-dev libjpeg-dev libfreetype6-dev libzip-dev libonig-dev libxml2-dev \
    && rm -rf /var/lib/apt/lists/*

# ===============================
# 3️⃣ Extensiones PHP
# ===============================
# COPY trae el instalador de extensiones desde la etapa multistage de mlocati
COPY --from=mlocati/php-extension-installer /usr/bin/install-php-extensions /usr/bin/
# RUN instala extensiones PHP necesarias para Magento
RUN install-php-extensions redis memcached mysqli pdo_mysql zip mbstring exif pcntl bcmath gd intl opcache soap xmlrpc xml sockets xsl ftp

# Asegurar compatibilidad: crear enlace simbólico si se necesita una versión por defecto
# (esta línea mantiene compatibilidad con la estructura esperada en algunas imágenes)
#RUN ln -s $PHP_INI_DIR/php.ini $PHP_INI_DIR/php.ini

# ===============================
# 4️⃣ Composer + Symfony
# ===============================
# Instalar Composer (gestor de dependencias PHP)
RUN curl -sS https://getcomposer.org/installer | php -- \
    --install-dir=/usr/local/bin \
    --filename=composer \
    --version=2.7.0

# Reemplazar configuración de sitio por una personalizada (asegurar AllowOverride y DocumentRoot)
COPY php/000-default-magento.conf /etc/apache2/sites-available/000-default.conf

# =============================== 
# 6️⃣ Xdebug 
# ===============================
# Instalar y habilitar Xdebug (útil en desarrollo)
#RUN install-php-extensions xdebug
# Copiar configuración de Xdebug (ajustes de remoto/cliente)
#COPY php/dev/xdebug.ini /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini

# Copiar archivo php.ini personalizado al directorio de configuración de PHP
# Esto sobrescribe la configuración por defecto (incluye memory_limit)
COPY php/php.ini /usr/local/etc/php/php.ini

#COPY php/uploads.ini /usr/local/etc/php/conf.d/uploads.ini

# ===============================
# 5️⃣ Apache + Magento ajustes
# ===============================
# Cambiar DocumentRoot de Apache para Magento (apunta a pub)
#ENV APACHE_DOCUMENT_ROOT /var/www/html/pub

# Habilitar mod_rewrite necesario para URLs amigables en Magento
RUN a2enmod rewrite         

# ===============================
# 7️⃣ Script de instalacióndocker exec -it magento php -i | grep memory_limitdocker exec -it magento php -i | grep memory_limit
# ===============================
# Copiar script personalizado que ejecuta la instalación/configuración de Magento al iniciar
COPY install-magento.sh /usr/local/bin/install-magento.sh
# Dar permiso de ejecución al script
RUN chmod +x /usr/local/bin/install-magento.sh

#===============================
# 8️⃣ Exponer puerto y comando por defecto
# ===============================
# Exponer el puerto 80 para HTTP
EXPOSE 80
# CMD se ejecuta al iniciar el contenedor: lanza el script de instalación/arranque
CMD ["/usr/local/bin/install-magento.sh"]